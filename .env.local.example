# ============================================================
# .env.local — Plateforme Immobilière CI (EXEMPLE — ne pas committer)
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# Base de données — connexion directe Render PostgreSQL
DATABASE_URL=postgresql://user:password@hostname:5432/immo_ci

# Upstash Redis — rate limiting OTP (service externe gratuit : upstash.com)
# @upstash/redis utilise l'API REST, PAS une connexion TCP standard
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Mapbox (token PUBLIC — lecture seule uniquement)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# PaiementPro (JAMAIS en NEXT_PUBLIC_)
PAIEMENTPRO_MERCHANT_ID=
PAYMENT_WEBHOOK_SECRET=       # openssl rand -hex 32
PAYMENT_PRO_CALLBACK_SECRET=  # Laisser VIDE — PaiementPro n'émet pas de HMAC
PAYMENT_PRO_CALLBACK_ORIGIN=https://paiementpro.net

# SMS OTP (Orange CI / africas-talking / twilio)
SMS_PROVIDER=africas_talking
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_USERNAME=

# Stockage médias — DigitalOcean Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_BUCKET=immo-ci-photos

# WhatsApp Business API (Meta)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Application
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=             # openssl rand -base64 32
ADMIN_PHONE=+22500000000

# Chiffrement TOTP (Sprint 2)
TOTP_ENCRYPTION_KEY=         # openssl rand -hex 32
